{
  "expo": {
    "name": "Nudgli",
    "slug": "nudgli",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "nudgli",
    "privacy": "public",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nudgli.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Nudgli does not use your camera.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B1D3A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "organization": "nudgli",
          "project": "nudgli-mobile"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0CBFA6"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "com.nudgli.app"
      },
      "privacyPolicyUrl": "https://www.nudgli.app/privacy",
      "termsOfServiceUrl": "https://www.nudgli.app/terms"
    }
  }
}
